ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a bad way, it can cause merge conflicts.
#   .env files containing sensitive variables should also be ignored:
# .env
# .env.*
# Pipfile.lock

# poetry
#   Similarly, poetry.lock is usually committed, but can be ignored.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is usually committed, but can be ignored.
# pdm.lock
.pdm-plugins/
.pdm-python/

# ruff
.ruff_cache/

# LSP
.pdm-lsp/

